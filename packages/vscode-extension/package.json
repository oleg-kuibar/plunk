{
  "name": "knarr-vscode",
  "displayName": "Knarr",
  "description": "Visualize Knarr-linked packages in your workspace",
  "version": "0.1.0",
  "publisher": "olegkuibar",
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./dist/extension.js",
  "activationEvents": [
    "workspaceContains:**/.knarr/state.json"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "knarr-explorer",
          "title": "Knarr",
          "icon": "resources/knarr-icon.svg"
        }
      ]
    },
    "views": {
      "knarr-explorer": [
        {
          "id": "knarr.linkedPackages",
          "name": "Linked Packages"
        }
      ]
    },
    "commands": [
      {
        "command": "knarr.refresh",
        "title": "Refresh",
        "category": "Knarr",
        "icon": "$(refresh)"
      },
      {
        "command": "knarr.showGraph",
        "title": "Show Dependency Graph",
        "category": "Knarr"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "knarr.refresh",
          "when": "view == knarr.linkedPackages",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "build": "node esbuild.config.mjs",
    "watch": "node esbuild.config.mjs --watch",
    "package": "vsce package --no-dependencies"
  },
  "devDependencies": {
    "@types/vscode": "^1.116.0",
    "esbuild": "^0.28.0",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "elkjs": "^0.11.1"
  }
}
