{
  "name": "plunk-vscode",
  "displayName": "Plunk",
  "description": "Visualize plunk-linked packages in your workspace",
  "version": "0.1.0",
  "publisher": "olegkuibar",
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./dist/extension.js",
  "activationEvents": [
    "workspaceContains:**/.plunk/state.json"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "plunk-explorer",
          "title": "Plunk",
          "icon": "resources/plunk-icon.svg"
        }
      ]
    },
    "views": {
      "plunk-explorer": [
        {
          "id": "plunk.linkedPackages",
          "name": "Linked Packages"
        }
      ]
    },
    "commands": [
      {
        "command": "plunk.refresh",
        "title": "Refresh",
        "category": "Plunk",
        "icon": "$(refresh)"
      },
      {
        "command": "plunk.showGraph",
        "title": "Show Dependency Graph",
        "category": "Plunk"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "plunk.refresh",
          "when": "view == plunk.linkedPackages",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "build": "node esbuild.config.mjs",
    "watch": "node esbuild.config.mjs --watch",
    "package": "vsce package --no-dependencies"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.27.3",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "elkjs": "^0.11.1"
  }
}
